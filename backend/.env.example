APP_NAME=deepkin-dubbing-backend
API_PREFIX=/api
APP_VERSION=0.1.0
APP_DESCRIPTION=Async video dubbing backend using transcript translation and DeepKIN TTS.
OPENAPI_URL=/openapi.json
DOCS_URL=/swagger
# Set empty to disable ReDoc in production.
REDOC_URL=
MAX_UPLOAD_SIZE_BYTES=10485760
MAX_VIDEO_DURATION_SECONDS=180
ALLOWED_EXTENSIONS=mp4,mov,m4v,webm

GENERATE_SIGNED_URL_ENDPOINT=https://tfo7lcvae5.execute-api.us-east-1.amazonaws.com/prod/generate-upload-url
INPUT_BUCKET=cmu-aisd-input
OUTPUT_BUCKET=cmu-aisd-output
ARTIFACT_BUCKET=cmu-aisd-artifacts
PUBLIC_PREFIX=public
PUBLIC_ARTIFACT_STORE=https://cmu-aisd-artifacts.s3.us-east-1.amazonaws.com

TRANSCRIPT_POLL_INTERVAL_SECONDS=5
TRANSCRIPT_TIMEOUT_SECONDS=600

TRANSLATION_MODEL_NAME=facebook/nllb-200-distilled-600M
TTS_MODEL_PATH=/app/kinya_flex_tts_base_trained.pt
SPEAKER_ID=1
